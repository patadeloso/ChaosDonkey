{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"./hooks/pre-tool.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"./hooks/post-tool.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
